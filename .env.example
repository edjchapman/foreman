# Copy to .env for local (non-Docker) runs. docker-compose sets these itself.
DATABASE_URL=postgres://foreman:foreman@localhost:5432/foreman
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Celery / Redis (M2). Broker + result backend default to REDIS_URL.
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_TASK_ALWAYS_EAGER=true   # run tasks inline (tests / no-broker local runs)
# OUTBOX_POLL_SECONDS=1.0          # how often beat polls the outbox

# M3 reliability (retries, backoff, dead-letter, lease) — defaults shown.
# RECOVER_POLL_SECONDS=5.0             # how often beat re-dispatches due retries
# JOB_MAX_ATTEMPTS=3                   # attempts (incl. the first) before dead-letter
# JOB_RETRY_BASE_SECONDS=2            # backoff base; ceiling doubles per attempt
# JOB_RETRY_MAX_SECONDS=300           # backoff cap
# JOB_LEASE_SECONDS=120               # worker lease TTL while PROCESSING
# JOB_REQUEUE_VISIBILITY_SECONDS=60   # re-dispatch visibility window for due retries

# M3 worker durability (at-least-once delivery + crash recovery) — defaults shown.
# CELERY_TASK_ACKS_LATE=true              # ack after the task finishes, not before
# CELERY_TASK_REJECT_ON_WORKER_LOST=true  # re-queue if the worker is killed mid-task
# CELERY_WORKER_PREFETCH_MULTIPLIER=1     # at most one unacked task per worker
# CELERY_VISIBILITY_TIMEOUT=3600          # broker redelivery backstop (seconds)

# M4 observability — defaults shown.
# DJANGO_LOG_FORMAT=json   # structured JSON logs (default) | console (human-readable dev)
